# The program keypair no longer lives here — it is materialized into
# target/deploy/ at build time from its canonical home keys/AAAA.json
# (see the `program-keypair` Makefile target), so target/ is ignored
# wholesale again.
target/

# Node / pnpm workspace (hoisted to the repo root by pnpm-workspace.yaml).
node_modules/

# wasm-pack output for the price-core WASM package (built via `make wasm`).
sdk/price-core/pkg/

# Background audit-loop state (see .claude/skills/audit-loop).
.audit-loop/

# macOS metadata.
.DS_Store
